# Keep source/config files consistent across Windows, Android, and CI.
* text=auto eol=lf

# Generated dependencies and build output should not be normalized or diffed.
node_modules/** binary
dist/** binary

# Windows command scripts should retain native Windows line endings.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets must never be line-ending normalized.
*.apk binary
*.db binary
*.gif binary
*.ico binary
*.jar binary
*.jpeg binary
*.jpg binary
*.jks binary
*.keystore binary
*.otf binary
*.pdf binary
*.png binary
*.sqlite binary
*.sqlite3 binary
*.ttf binary
*.webp binary
*.woff binary
*.woff2 binary
*.zip binary
